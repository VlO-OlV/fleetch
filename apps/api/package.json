{
  "name": "api",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "packageManager": "yarn@4.6.0",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\"",
    "format-check": "prettier --check \"src/**/*.ts\"",
    "start": "nest start",
    "start:dev": "NODE_ENV=development nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "NODE_ENV=production node dist/main",
    "lint": "eslint . --fix src/**/*.ts",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:db:prepare": "docker compose --env-file .env.testing -f docker-compose.test.yml up -d && dotenv -e .env.testing -- npx prisma migrate reset --force --skip-seed",
    "test:db:down": "docker compose --env-file .env.testing -f docker-compose.test.yml down -v",
    "test:unit": "jest --config jest-unit.config.ts",
    "test:unit:coverage": "jest --config jest-unit.config.ts --coverage",
    "test:integration": "npm run test:db:prepare && jest --config jest-integration.config.ts && npm run test:db:down",
    "test:integration:coverage": "npm run test:db:prepare && jest --config jest-integration.config.ts --coverage && npm run test:db:down",
    "test:e2e": "npm run test:db:prepare && jest --config jest-e2e.config.ts && npm run test:db:down",
    "test:e2e:coverage": "npm run test:db:prepare && jest --config jest-e2e.config.ts --coverage && npm run test:db:down",
    "test": "npm run test:unit && npm run test:integration && npm run test:e2e",
    "test:coverage": "npm run test:unit:coverage && npm run test:integration:coverage && npm run test:e2e:coverage",
    "prisma:migrate:dev": "dotenv -e .env.development -- npx prisma migrate dev",
    "prisma:migrate:prod": "dotenv -e .env.production -- npx prisma migrate deploy",
    "prisma:generate": "npx prisma generate",
    "docker:dev:start": "docker compose --env-file .env.development -f docker-compose.test.yml up",
    "docker:dev:stop": "docker compose --env-file .env.development -f docker-compose.test.yml down",
    "docker:prod:start": "docker compose --env-file .env.production -f docker-compose.yml up",
    "docker:prod:stop": "docker compose --env-file .env.production -f docker-compose.yml down"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.932.0",
    "@nestjs-modules/mailer": "^2.0.2",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.9",
    "@nestjs/swagger": "^11.2.3",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/throttler": "^6.4.0",
    "@prisma/client": "^6.16.3",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.70.4",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "cookie-parser": "^1.4.7",
    "ioredis": "^5.8.2",
    "multer": "^2.0.2",
    "nodemailer": "^7.0.10",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.9",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.10.7",
    "@types/nodemailer": "^7.0.3",
    "@types/passport": "^0",
    "@types/passport-google-oauth20": "^2",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^8.46.2",
    "@typescript-eslint/parser": "^8.46.2",
    "dotenv-cli": "^10.0.0",
    "eslint": "^9.38.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-unicorn": "^62.0.0",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.6.2",
    "prisma": "^6.16.3",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  }
}
