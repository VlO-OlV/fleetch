{
  "name": "fleetch",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "turbo run format",
    "format-check": "turbo run format-check",
    "check-types": "turbo run check-types",
    "prod:start": "docker compose --env-file ./apps/api/.env.production -f docker-compose.yml up",
    "prod:stop": "docker compose --env-file ./apps/api/.env.production -f docker-compose.yml down"
  },
  "devDependencies": {
    "prettier": "^3.6.2",
    "turbo": "^2.5.6",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "yarn@4.6.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
